# Cloudinary Configuration
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# Cloudinary Upload (server-side only — never expose these client-side)
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ElevenLabs (optional - agent ID is currently hardcoded)
# VITE_ELEVENLABS_AGENT_ID=agent_5801kf1z46zkfp9rcgrp96kpyeja

# Go High Level (GHL) Webhook for Contact Forms
# Create an Inbound Webhook in GHL: Settings → Integrations → Webhooks
GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/YOUR_WEBHOOK_ID
